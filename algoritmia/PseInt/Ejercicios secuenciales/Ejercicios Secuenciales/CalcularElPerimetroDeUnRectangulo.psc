Proceso CalcularElPerimetroDeUnRectangulo
	Definir perimetro, base, altura Como Real;
	Escribir "Calcular el perímetro de un rectángulo.  Ingrese la base y la altura (por separado)";
	Leer base, altura;
	perimetro <- 2 * (base + altura);
	Escribir "El perimetro del rectangulo es ", perimetro, "cm";
FinProceso
