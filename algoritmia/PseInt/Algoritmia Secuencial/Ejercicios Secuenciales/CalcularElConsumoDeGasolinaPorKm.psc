Proceso CalcularElConsumoDeGasolinaPorKm
	Definir gasolina, km, formula Como Real;
	Escribir "Calcular el consumo de gasolina por km. Ingrese la gasolina (L) y los km recorridos"; Leer gasolina, km;
	formula <- gasolina/km;
	Escribir "El consumo de gasolina sobre km es ", formula, " L/km";
FinProceso
