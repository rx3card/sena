Algoritmo CalcularAreaDeUnTriangulo
	Definir Base, Altura, Area Como Real;;
	Escribir "Por favor ingrese los datos a continuacion para conocer el Area de cualquier triangulo";
	Escribir "Ingrese la Base (cm)";
	Leer Base;
	Escribir "Ingrese la Altura (cm)";
	Leer Altura;
	Area <- (Base * Altura)/5;
	Escribir "El area del triangulo es: ", Area, " cm*2"; 
FinAlgoritmo
